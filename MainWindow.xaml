<!-- MainWindow.xaml -->
<Window x:Class="LearnSmart.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ЛёрнСмарт | Мониторинг успеваемости"
        Height="820" 
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Стиль для кнопок навигации в боковой панели -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Hover эффект -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E2937"/>
                </Trigger>
                <!-- Нажатая кнопка (активная) -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковая панель -->
        <Border Grid.Column="0" Background="#0F172A" CornerRadius="0,12,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <StackPanel Grid.Row="0" Margin="28" Orientation="Horizontal">
                    <TextBlock Text="🎓" FontSize="42" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="ЛЁРНСМАРТ" 
                                   Foreground="White" 
                                   FontSize="28" 
                                   FontWeight="Bold"/>
                        <TextBlock Text="Мониторинг успеваемости" 
                                   Foreground="#94A3B8" 
                                   FontSize="13"/>
                    </StackPanel>
                </StackPanel>

                <!-- Навигация -->
                <StackPanel Grid.Row="2" Margin="24,0">
                    <TextBlock Text="НАВИГАЦИЯ" 
                               Foreground="#94A3B8" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,16"/>

                    <Button Style="{StaticResource NavButton}" 
                            Content="🏠 Главная" 
                            Click="NavHome_Click"/>

                    <Button Style="{StaticResource NavButton}" 
                            Content="👥 Студенты" 
                            Click="NavStudents_Click"/>

                    <Button Style="{StaticResource NavButton}" 
                            Content="📚 Группы" 
                            Click="NavGroups_Click"/>
                </StackPanel>

                <!-- Кнопки действий внизу -->
                <StackPanel Grid.Row="3" Margin="24">
                    <Button Content="📊 Сгенерировать отчёт PDF" 
                            Click="BtnGenerateReport_Click"
                            Height="50" 
                            Background="#22C55E" 
                            Foreground="White" 
                            FontWeight="SemiBold" 
                            Margin="0,0,0,12"/>

                    <Button Content="📤 Экспорт в Excel" 
                            Click="BtnExportExcel_Click"
                            Height="46" 
                            Background="#3B82F6" 
                            Foreground="White" 
                            Margin="0,0,0,12"/>

                    <Button Content="🗑 Очистить данные" 
                            Click="BtnClearAll_Click"
                            Height="46" 
                            Background="#EF4444" 
                            Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область -->
        <Frame x:Name="MainFrame" 
               Grid.Column="1" 
               Margin="32" 
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>