<!-- Views/StudentsWindow.xaml -->
<UserControl x:Class="LearnSmart.Views.StudentsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" 
             d:DesignWidth="900">

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" Padding="24" CornerRadius="12"
                BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="👥" FontSize="32" Margin="0,0,16,0"/>
                <StackPanel>
                    <TextBlock Text="Студенты" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Управление списком студентов" Foreground="#64748B" FontSize="14"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Панель добавления студента -->
        <Border Grid.Row="1" Background="White" Padding="24" CornerRadius="12"
                BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtFullName" Grid.Column="0" Margin="0,0,12,0"
                         Height="48" Padding="16,0" FontSize="15"
                         Background="#F8FAFC" BorderBrush="#CBD5E1"
                         VerticalContentAlignment="Center"
                         ToolTip="ФИО студента"/>

                <ComboBox x:Name="cmbGroup" Grid.Column="1" Margin="0,0,12,0"
                          Height="48" FontSize="15" VerticalContentAlignment="Center"
                          ToolTip="Выберите группу"/>

                <Button Grid.Column="3" Content="➕ Добавить студента"
                        Click="BtnAddStudent_Click"
                        Width="180" Height="48"
                        Background="#0EA5E9" Foreground="White"
                        FontWeight="SemiBold" FontSize="15"/>
            </Grid>
        </Border>

        <!-- Список студентов -->
        <DataGrid x:Name="dgStudents" Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  RowHeight="60"
                  Background="White"
                  BorderBrush="#E2E8F0"
                  AlternatingRowBackground="#F8FAFC"
                  MouseDoubleClick="DgStudents_MouseDoubleClick"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" IsReadOnly="True"/>
                <DataGridTextColumn Header="ФИО студента" Binding="{Binding FullName}" Width="3*"/>
                <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="1.5*"/>
                <DataGridTextColumn Header="Средний балл" Binding="{Binding AverageScore, StringFormat=F1}" Width="120"/>
                <DataGridTemplateColumn Header="Статус" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding StatusBg}" Padding="12,6" CornerRadius="8">
                                <TextBlock Text="{Binding Status}"
                                           Foreground="{Binding StatusColor}"
                                           FontWeight="SemiBold" 
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>