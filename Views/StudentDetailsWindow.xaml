<!-- Views/StudentDetailsWindow.xaml -->
<Window x:Class="LearnSmart.Views.StudentDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка студента" 
        Height="720" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC"
        FontFamily="Segoe UI">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая колонка - Информация о студенте -->
        <StackPanel Grid.Column="0" Margin="0,0,24,0">
            <Border Background="White" CornerRadius="16" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <Ellipse Width="120" Height="120" Fill="#E2E8F0" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtStudentName" Text="Фамилия Имя Отчество" 
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,16,0,4"/>
                    <TextBlock x:Name="txtGroupName" Text="Группа ИС-23-1" 
                               Foreground="#64748B" HorizontalAlignment="Center" FontSize="15"/>

                    <Separator Margin="0,20"/>

                    <StackPanel>
                        <TextBlock Text="Средний балл" Foreground="#64748B" FontSize="13"/>
                        <TextBlock x:Name="txtAvgScore" Text="84.6" FontSize="32" FontWeight="Bold" Foreground="#22D3EE"/>
                    </StackPanel>

                    <Button Content="Редактировать данные" Margin="0,24,0,0"
                            Background="#3B82F6" Foreground="White" Height="44" FontWeight="Medium"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Правая колонка - История оценок -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="История оценок и тестов" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <DataGrid x:Name="dgStudentResults" Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      RowHeight="52"
                      Background="White"
                      BorderBrush="#E2E8F0">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="110"/>
                    <DataGridTextColumn Header="Модуль / Тест" Binding="{Binding TestName}" Width="3*"/>
                    <DataGridTextColumn Header="Балл" Binding="{Binding Score}" Width="100"/>
                    <DataGridTemplateColumn Header="Статус" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding StatusBg}" Padding="12,6" CornerRadius="8">
                                    <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>